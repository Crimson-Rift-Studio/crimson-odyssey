{
  "schemaVersion": 3,
  "ui": {
    "sidebarBreakpoint": 110,
    "sidebarWidth": 34,
    "theme": "crimson",
    "mouse": true,
    "showReasoningSummary": true
  },
  "models": {
    "cacheTtlHours": 24,
    "fallback": "ask"
  },
  "history": {
    "retentionDays": 90
  },
  "security": {
    "ownerOnly": true,
    "redactLogs": true,
    "allowShell": false
  },
  "updates": {
    "mode": "notify",
    "channel": "stable",
    "intervalHours": 24,
    "repository": "aabrur/crimson-odyssey",
    "branch": "main"
  },
  "setup": {
    "completed": false,
    "version": null,
    "completedAt": null
  },
  "providers": {
    "openai": {
      "secretRef": "vault:openai-api-key"
    },
    "ollama": {
      "baseUrl": "http://127.0.0.1:11434"
    },
    "custom": {
      "baseUrl": "http://127.0.0.1:8000/v1",
      "secretRef": "vault:custom-api-key"
    }
  }
}
